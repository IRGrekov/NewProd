// commit.js — делает маленький автокоммит с фронтенд-подобным изменением
const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

function run(cmd) {
  return execSync(cmd, { stdio: 'pipe', encoding: 'utf8' }).trim();
}

function randomFrom(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

const messages = [
  "feat(ui): add new component",
  "refactor: improve code structure",
  "fix: minor bug in component rendering",
  "style: adjust layout spacing",
  "chore: update dependencies",
  "docs: update README with setup notes"
];

function makeComponent() {
  const now = new Date().toISOString();
  const dir = path.join(process.cwd(), 'src', 'components');
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });

  const names = ['Header', 'Footer', 'Card', 'Modal', 'Sidebar', 'Widget'];
  const name = randomFrom(names) + Math.floor(Math.random() * 1000);
  const file = path.join(dir, `${name}.jsx`);
  const content = `// ${name} — autogenerated\n` +
`import React from 'react';\n\n` +
`export default function ${name}() {\n` +
`  return <div className="${name.toLowerCase()}">Generated ${name} at ${now}</div>;\n` +
`}\n`;
  fs.writeFileSync(file, content, 'utf8');
  return file;
}

function commitAndPush(message) {
  run('git add -A');
  try {
    run(`git commit -m "${message}" --author="Frontend Bot <bot@example.com>"`);
  } catch (e) {
    if (e.message.includes('nothing to commit')) {
      console.log('Nothing new to commit.');
      return false;
    } else throw e;
  }
  run('git push');
  console.log('✅ Pushed:', message);
  return true;
}

(function main() {
  makeComponent();
  const msg = randomFrom(messages);
  commitAndPush(msg);
})();

